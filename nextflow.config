manifest.nextflowVersion = '>=25.10.2'
manifest.author.orcid = '0000-0002-9923-6878'
manifest.author.name = 'Hassan Massalha'
manifest.defaultBranch = 'main'
manifest.description = 'DRIP-seq STAR Protocol: A Nextflow pipeline for processing DRIP-seq'
manifest.gitmodules = true
manifest.homePage = 'https://github.com/MCrossleyLab/DRIP-seq_STAR_Protocol'
manifest.recurseSubmodules = true


params {
    base_dir                = params.outdir_path
    outdir                  = "${base_dir}/${params.outdir_name}"
    genome_path             = "${HOME}/Genomics/indexes"    // directory that contains hg38.chrom.sizes
    bowtie2_extra_params    = '--no-unal --no-mixed --no-discordant'
    bowtie2_index_suffix    = ""                            // Optional: suffix to add, if you name indexes like hg38_mm10_spike
    species_list            = []                            // Optional: suffix to add, if you name indexes like hg38_mm10_spike
}

workDir = "${params.base_dir}/.work"

profiles {
    local {
        process {
            executor = 'local'
            conda = "${HOME}/DRIP-seq_STAR_Protocol/explicit.txt"
            // conda = "${HOME}/miniconda3/envs/preprocessing"
        }
    }

    slurmc {
        process {
            executor = 'slurm'
            cpus = '8'
            memory = '4G'
            time = '30min'
            queue = 'epyc'
            conda = "${HOME}/DRIP-seq_STAR_Protocol/explicit.txt"
            // conda = "${HOME}/miniconda3/envs/preprocessing"
            withName: 'BOWTIE2_ALIGN' { 
                cpus = '20'
                memory = 16.GB
                time = '4h'
            }
            // markdup_bams
            withName: 'SAMTOOLS_COLLATE|SAMTOOLS_FIXMATE|SAMTOOLS_SORT|SAMTOOLS_MARKDUP_INDEX' {
                errorStrategy = 'retry'
                maxRetries    = 3          // 1st + 3 retries = up to 4 attempts
                memory = {
                    def base = 10.GB
                    def m = base * (2 ** (task.attempt - 1))
                    m > 16.GB ? 16.GB : m
                }
            }
            
            // deeptools
            withName: 'BAMCOVERAGE' {
                memory = 20.GB
                cpus = '20'
            }
        }
    }

    conda { 
        enable_conda = true
    }
}